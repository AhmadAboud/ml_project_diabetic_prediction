from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import brier_score_loss, roc_auc_score
from sklearn.calibration import calibration_curve
import matplotlib.pyplot as plt

model = RandomForestClassifier(n_estimators=100, random_state=42)
model.fit(X_train, y_train)

Vorhersage = model.predict_proba(X_test)[:, 1]

brier = brier_score_loss(y_test, Vorhersage)
roc_auc = roc_auc_score(y_test, Vorhersage)

print("Brier Score:", brier)
print("ROC-AUC:", roc_auc)

Vorhersage_true, Vorhersage_pred = calibration_curve(y_test, Vorhersage, n_bins=10)

plt.plot(Vorhersage_pred, Vorhersage_true, marker="o")
plt.plot([0, 1], [0, 1], "--")
plt.xlabel("Mittlere voraussehbare Wahrscheinlichkeit")
plt.ylabel("Anteil der pos.Fälle")
plt.title("Kalibrierungs Kurve")
plt.grid(True)
plt.show()
